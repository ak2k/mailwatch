# mailwatch configuration — copy to .env and fill in real values.
# Every value here is a placeholder. The real .env file must NEVER be committed.

# USPS Mailer Identity
# Obtained from USPS Business Customer Gateway (https://gateway.usps.com)
MAILER_ID=123456789              # 6 or 9 digit MID assigned by USPS
SRV_TYPE=40                      # IMb Service Type (40 = First-Class Single-Piece Full-Service)
BARCODE_ID=0                     # 2-digit Barcode ID; 0 unless doing OEL routing

# USPS IV-MTR (Informed Visibility - Mail Tracking & Reporting)
# BCG login credentials for services.usps.com OAuth
BSG_USERNAME=your-bcg-username
BSG_PASSWORD=your-bcg-password

# USPS Developer API (apis.usps.com) OAuth client credentials
# From https://developer.usps.com
USPS_NEWAPI_CUSTOMER_ID=your-oauth-client-id
USPS_NEWAPI_CUSTOMER_SECRET=your-oauth-client-secret

# Session cookie signing
# Generate with: openssl rand -hex 32
SESSION_KEY=replace-with-openssl-rand-hex-32

# Storage
DB_PATH=./mailwatch.db           # SQLite file path; use /var/lib/mailwatch/mailwatch.db in prod

# Rate limiting (USPS apis.usps.com default = 60 req/hr; request tier upgrade to 300)
RATE_LIMIT_PER_HOUR=50           # Client-side cap, leaves headroom under the USPS limit

# Webhook IP allowlist for /usps_feed (IV-MTR push feed source ranges).
# Comma-separated CIDRs. Verify current list at provisioning time.
USPS_FEED_CIDRS=56.0.0.0/8
